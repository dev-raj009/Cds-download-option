# ============================================================
# SpidyUniverse CDS - Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values

# API Security Key - Change this to a random 64-char string
# Generate: openssl rand -hex 32
API_SECRET_KEY=CHANGE_THIS_TO_YOUR_SECRET_64_CHAR_HEX_KEY_HERE

# AES Encryption Key (32 chars for AES-256)
# Generate: openssl rand -hex 16
AES_ENCRYPTION_KEY=CHANGE_THIS_32_CHAR_KEY_HERE____

# AES IV (16 chars)
AES_IV=CHANGE_THIS_16IV

# Token expiry in minutes (default: 60)
TOKEN_EXPIRY_MINUTES=60
